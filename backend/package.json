{
  "name": "linkup-be",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "preinstall": "npx only-allow bun",
    "postinstall": "bun prisma:generate",
    "dev": "nodemon -r dotenv/config src/server.ts",
    "start": "npm run build && npm run serve",
    "serve": "node -r dotenv/config dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "db:migrate-dev": "prisma migrate dev",
    "db:migrate-reset": "prisma migrate reset",
    "db:migrate-prod": "prisma migrate deploy",
    "studio": "prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}